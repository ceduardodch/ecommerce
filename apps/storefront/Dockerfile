FROM node:20-bookworm-slim AS deps

WORKDIR /app

ENV NODE_ENV=production
ENV NPM_CONFIG_UPDATE_NOTIFIER=false

ARG NEXT_PUBLIC_TOOLS_API_URL
ARG NEXT_PUBLIC_STORE_URL
ARG NEXT_PUBLIC_COCINA_URL
ARG NEXT_PUBLIC_BIENESTAR_URL
ARG NEXT_PUBLIC_PIXEL_ENABLED
ARG NEXT_PUBLIC_META_PIXEL_ID
ARG NEXT_PUBLIC_PIXEL_CONSENT_MODE
ARG NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER
ENV NEXT_PUBLIC_TOOLS_API_URL=$NEXT_PUBLIC_TOOLS_API_URL
ENV NEXT_PUBLIC_STORE_URL=$NEXT_PUBLIC_STORE_URL
ENV NEXT_PUBLIC_COCINA_URL=$NEXT_PUBLIC_COCINA_URL
ENV NEXT_PUBLIC_BIENESTAR_URL=$NEXT_PUBLIC_BIENESTAR_URL
ENV NEXT_PUBLIC_PIXEL_ENABLED=$NEXT_PUBLIC_PIXEL_ENABLED
ENV NEXT_PUBLIC_META_PIXEL_ID=$NEXT_PUBLIC_META_PIXEL_ID
ENV NEXT_PUBLIC_PIXEL_CONSENT_MODE=$NEXT_PUBLIC_PIXEL_CONSENT_MODE
ENV NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER=$NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER

COPY package.json package-lock.json turbo.json ./
COPY apps/backend/package.json apps/backend/package.json
COPY apps/storefront/package.json apps/storefront/package.json
COPY services/ecommerce-tools/package.json services/ecommerce-tools/package.json
RUN npm ci --legacy-peer-deps --include=dev

FROM deps AS builder

WORKDIR /app

ARG NEXT_PUBLIC_TOOLS_API_URL
ARG NEXT_PUBLIC_STORE_URL
ARG NEXT_PUBLIC_COCINA_URL
ARG NEXT_PUBLIC_BIENESTAR_URL
ARG NEXT_PUBLIC_PIXEL_ENABLED
ARG NEXT_PUBLIC_META_PIXEL_ID
ARG NEXT_PUBLIC_PIXEL_CONSENT_MODE
ARG NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER
ENV NEXT_PUBLIC_TOOLS_API_URL=$NEXT_PUBLIC_TOOLS_API_URL
ENV NEXT_PUBLIC_STORE_URL=$NEXT_PUBLIC_STORE_URL
ENV NEXT_PUBLIC_COCINA_URL=$NEXT_PUBLIC_COCINA_URL
ENV NEXT_PUBLIC_BIENESTAR_URL=$NEXT_PUBLIC_BIENESTAR_URL
ENV NEXT_PUBLIC_PIXEL_ENABLED=$NEXT_PUBLIC_PIXEL_ENABLED
ENV NEXT_PUBLIC_META_PIXEL_ID=$NEXT_PUBLIC_META_PIXEL_ID
ENV NEXT_PUBLIC_PIXEL_CONSENT_MODE=$NEXT_PUBLIC_PIXEL_CONSENT_MODE
ENV NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER=$NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER

COPY . .
RUN npm run storefront:build

FROM node:20-bookworm-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NPM_CONFIG_UPDATE_NOTIFIER=false
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=builder /app/apps/storefront/.next/standalone ./
COPY --from=builder /app/apps/storefront/.next/static ./apps/storefront/.next/static
COPY --from=builder /app/apps/storefront/public ./apps/storefront/public

EXPOSE 3000

CMD ["node", "apps/storefront/server.js"]
