# Public URLs
STORE_PUBLIC_URL=https://shop.b2b.com.ec
NEXT_PUBLIC_STORE_URL=https://shop.b2b.com.ec
NEXT_PUBLIC_TOOLS_API_URL=https://shop.b2b.com.ec

# Medusa
DATABASE_URL=postgres://postgres:postgres@postgres:5432/medusa-store
REDIS_URL=redis://redis:6379
STORE_CORS=http://localhost:3000,https://shop.b2b.com.ec
ADMIN_CORS=http://localhost:9000,https://shop.b2b.com.ec
AUTH_CORS=http://localhost:9000,https://shop.b2b.com.ec
JWT_SECRET=change-me
COOKIE_SECRET=change-me
MEDUSA_PUBLISHABLE_KEY=

# Ecommerce tools
TOOLS_PORT=8787
TOOLS_DATA_DIR=/data
TOOLS_API_TOKEN=change-me
MEDUSA_STORE_API_URL=http://medusa-api:9000
MEDUSA_ADMIN_API_URL=http://medusa-api:9000
MEDUSA_ADMIN_API_KEY=
ECOMMERCE_TAX_RATE=0.15
WHATSAPP_SELLER_NUMBER=593999999999

# PayPhone API Link
PAYPHONE_API_LINK_URL=https://pay.payphonetodoesposible.com/api/Links
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=
PAYPHONE_DRY_RUN=true

# Meta catalog and organic publishing
META_CATALOG_BRAND=B2B
META_ENV_PATH=/run/secrets/meta_env
META_API_VERSION=v23.0
