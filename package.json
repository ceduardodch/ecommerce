{
  "name": "b2b-ai-native-ecommerce",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "backend:dev": "turbo dev --filter=@b2b/medusa-backend",
    "backend:build": "turbo build --filter=@b2b/medusa-backend",
    "backend:start": "turbo start --filter=@b2b/medusa-backend",
    "backend:seed": "turbo seed --filter=@b2b/medusa-backend",
    "storefront:dev": "turbo dev --filter=@b2b/storefront",
    "storefront:build": "turbo build --filter=@b2b/storefront",
    "storefront:start": "turbo start --filter=@b2b/storefront",
    "tools:dev": "turbo dev --filter=@b2b/ecommerce-tools",
    "tools:build": "turbo build --filter=@b2b/ecommerce-tools",
    "tools:start": "turbo start --filter=@b2b/ecommerce-tools",
    "tools:test": "turbo test --filter=@b2b/ecommerce-tools",
    "biblioteca:metadata": "node scripts/generate-biblioteca-metadata.mjs",
    "validate:meta-whatsapp": "node scripts/validate-meta-whatsapp-flow.mjs",
    "validate:cuchillo-release": "node scripts/validate-cuchillo-release-package.mjs",
    "datafast:probe": "node scripts/datafast-certification-probe.mjs",
    "campaign:readiness": "node scripts/campaign-readiness-report.mjs",
    "crm:reset": "node scripts/reset-medusa-crm.mjs",
    "graphify:build": "uv tool run --from graphifyy graphify extract . --code-only",
    "graphify:build:full": "uv tool run --from graphifyy graphify extract .",
    "graphify:update": "uv tool run --from graphifyy graphify update .",
    "graphify:query": "uv tool run --from graphifyy graphify query",
    "graphify:diagnose": "uv tool run --from graphifyy graphify diagnose multigraph"
  },
  "devDependencies": {
    "pg": "^8.21.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "services/**",
    "!apps/backend/.medusa/**",
    "!apps/storefront/.next/**"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  }
}
